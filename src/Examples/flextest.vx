# examples/generics.vx - Full test suite for working features.
# Unsupported features are commented out.

# =============================================================================
# WORKING: Option and Result as monomorphic enums
# =============================================================================

fn option_demo() -> i32:
    let some_val: Option = Option::Some
    let none_val: Option = Option::None
    let a = match some_val:
        Option::Some -> 42
        Option::None -> 0
    }
    let b = match none_val:
        Option::Some -> 10
        Option::None -> 5
    }
    return a + b
}

fn may_fail(flag: i32) -> Result:
    if flag == 0:
        return Result::Ok
    }
    return Result::Err
}

fn use_question(flag: i32) -> i32:
    let res = may_fail(flag)
    return match res:
        Result::Ok -> 101
        Result::Err -> 0
    }
}

fn match_demo() -> i32:
    let opt: Option = Option::Some
    return match opt:
        Option::Some -> 1
        Option::None -> 0
    }
}

fn match_ref_demo(opt: &Option) -> i32:
    return match opt:
        &Option::Some -> 100
        &Option::None -> 0
    }
}

# =============================================================================
# WORKING: Generic functions (monomorphisation)
# =============================================================================

fn identity<T>(x: T) -> T:
    return x
}

fn generic_caller<T>(x: T) -> T:
    let y = identity(x)
    return y
}

fn test_generics() -> i32:
    let a = identity(42)
    let b = identity(3.14)
    let c = identity(Option::Some)
    let d = identity(Result::Ok)
    let some_opt = Option::Some
    let e = identity(&some_opt)
    let f = identity("hello")
    let g = generic_caller(100)
    assert(a == 42, "identity failed")
    assert(g == 100, "generic_caller failed")
    return 0
}

# =============================================================================
# WORKING: Generic structs and Vec<T> (runtime bug present – to be fixed)
# =============================================================================

struct Vec<T>:
    ptr: i8*
    len: i64
    cap: i64
}

struct Pair<A, B>:
    first: A
    second: B
}

fn new_vec<T>() -> Vec<T>:
    return Vec(ptr: 0 as i8*, len: 0 as i64, cap: 0 as i64)
}

fn new_pair<A, B>(a: A, b: B) -> Pair<A, B>:
    return Pair(first: a, second: b)
}

fn get_len<T>(v: &Vec<T>) -> i64:
    return v.len
}

fn get_ptr<T>(v: &Vec<T>) -> i8*:
    return v.ptr
}

fn test_vec() -> i32:
    let mut v: Vec<i32> = new_vec()
    push(v, 10)
    push(v, 20)
    push(v, 30)
    assert(len(v) == 3, "len after pushes")
    let x = pop(v)
    assert(x == Some(30), "pop returns last")
    assert(len(v) == 2, "len after pop")
    let y = pop(v)
    assert(y == Some(20), "pop second")
    assert(v[0] == 10, "index works")
    return 0
}

# =============================================================================
# WORKING: if let
# =============================================================================

fn test_if_let(opt: Option) -> i32:
    if let Option::Some = opt:
        return 1
    } else:
        return 0
    }
}

