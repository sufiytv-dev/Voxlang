# 2. `?` operator – unsupported
 fn may_fail_generic(flag: i32) -> Result<i32, &str>:
     if flag == 0:
         return Result::Ok(42)
     } else:
         return Result::Err("error")
     }
 }

 fn test_question() -> Result<i32, &str>:
    let x = may_fail_generic(0)?
    return Result::Ok(x)
 }

