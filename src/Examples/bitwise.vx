fn main() -> i32:
    let a: i32 = 12   # 0b1100
    let b: i32 = 10   # 0b1010
    let and_val: i32 = a & b
    let or_val: i32 = a | b
    let xor_val: i32 = a ^ b
    let shl_val: i32 = a << 2
    let shr_val: i32 = a >> 1
    let rem_val: i32 = 17 % 5
    let result: i32 = and_val + or_val + xor_val + shl_val + shr_val + rem_val
    if result == 84:
        return 0 }
    else:
        return 1 }
}
