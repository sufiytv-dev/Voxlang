# test_use.vx - Comprehensive test for `use` statement functionality
# This file should be placed in examples/ along with math.vx

import "lib/math.vx" as math

fn main() -> i32:
    let sum = math::add(10, 20)          # 30
    let diff = math::sub(30, 10)         # 20
    let prod = math::mul(5, 6)           # 30
    let p = math::Point(x: 10, y: 20)

    return sum + diff + prod + p.x + p.y   # 110
}
